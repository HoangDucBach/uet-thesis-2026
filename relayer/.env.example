# Network configuration
NETWORK=testnet

# Admin private key for signing transactions
ADMIN_PRIVATE_KEY=your_private_key_here

# COW DEX package ID
COW_DEX_PACKAGE_ID=your_package_id_here

# Global config object ID  
GLOBAL_CONFIG_ID=your_global_config_id_here

# Deepbook package ID (optional)
DEEPBOOK_PACKAGE_ID=

# Deepbook registry ID (optional)
DEEPBOOK_REGISTRY_ID=

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# gRPC Sidecar configuration
# The sidecar streams real-time COW events from Sui indexer
GRPC_HOST=localhost
GRPC_PORT=50051
