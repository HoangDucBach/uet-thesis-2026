      ]
    },
    "consume_intent_partial": {
      "source_index": 3,
      "index": 3,
      "doc": " Partially fill an intent during settlement.\n Intent stays alive — NOT deleted. Balance is split, filled_amount updated.\n Caller must ensure fill_amount > 0 and intent is partial_fillable.\n\n * `intent`: Mutable reference to the shared Intent.\n * `fill_amount`: Amount of SellCoin to fill (must be <= remaining balance).\n Returns: (owner address, partial_sell_balance, proportional_min_out)\n\n proportional_min_out = min_amount_out * fill_amount / original_sell_amount\n where original_sell_amount = remaining + already_filled (reconstructed).",
      "attributes": [],
      "visibility": "Package",
      "entry": false,
      "type_parameters": [
        {
          "name": "SellCoin",
          "constraints": []
        },
