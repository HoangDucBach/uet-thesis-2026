    "consume_intent": {
      "source_index": 2,
      "index": 2,
      "doc": " Consume intent during settlement.\n\n * `intent`: Intent taken by value (deleted atomically).\n Returns: (owner address, sell_balance, min_amount_out)\n Caller derives sell_amount via `balance::value(&sell_balance)`.\n\n Type Parameters:\n * `SellCoin`: Coin type user was selling.\n * `BuyCoin`: Coin type user wanted to receive.",
      "attributes": [],
      "visibility": "Package",
      "entry": false,
      "type_parameters": [
