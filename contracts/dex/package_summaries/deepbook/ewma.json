    "z_score": {
      "source_index": 2,
      "index": 2,
      "doc": " Returns the Z-score of the current gas price relative to the smoothed mean and variance.\n The Z-score is calculated as the difference between the current gas price and the mean,\n divided by the standard deviation (square root of variance).",
